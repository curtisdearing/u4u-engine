# ── U4U Engine Environment Variables ──────────────────────────────────────────
# Copy this file to .env and fill in the values:
#   cp .env.example .env

# NCBI API key — optional but recommended.
# Raises ClinVar rate limit from 3 to 10 requests/second.
# Get one free at: https://www.ncbi.nlm.nih.gov/account/settings/
NCBI_API_KEY=

# Path to rsID filter files inside the container (default: data)
# DATA_DIR=data

# Comma-separated filter filenames (default: acmg81_rsids.txt)
# Set to empty string to run all variants without a panel filter.
# FILTERS=acmg81_rsids.txt

# Thread pool size for concurrent pipeline runs (default: 4)
# WORKERS=4

# Maximum upload file size in megabytes (default: 100)
# MAX_UPLOAD_MB=100

# Hours to keep completed jobs in memory before cleanup (default: 24)
# JOB_TTL_HOURS=24

# Frontend API base URL — set this when running the frontend container
# NEXT_PUBLIC_API_BASE=http://localhost:8000
