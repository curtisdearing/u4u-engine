# Copy this file to .env and fill in values before running.
# .env is gitignored — never commit real keys.

# NCBI API key — free, raises ClinVar rate limit from 3 req/s to 10 req/s.
# Register at: https://www.ncbi.nlm.nih.gov/account/
# Without this, annotation will be the bottleneck under any real load.
NCBI_API_KEY=

# Directory containing rsID filter files (acmg81_rsids.txt, etc.)
# Default: "data" (relative to repo root / working directory)
DATA_DIR=data

# Comma-separated filter filenames to apply. Pipeline keeps only variants
# whose rsID appears in at least one file.
# Set to "" to run all variants (no panel filter).
FILTERS=acmg81_rsids.txt

# Number of threads in the pipeline thread pool.
# Each thread handles one /analyze request end-to-end.
# Set to match available CPUs on the host.
WORKERS=4

# Maximum upload file size in MB. Pipeline also enforces 100 MB internally.
MAX_UPLOAD_MB=100
